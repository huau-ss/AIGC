{
  "name": "academic-rewrite-platform",
  "version": "0.1.0",
  "description": "AI-powered academic paper rewriting platform with MCP support",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:api": "tsx watch src/api/server.ts",
    "dev:mcp": "tsx watch src/mcp/server.ts",
    "start": "node dist/index.js",
    "start:api": "node dist/api/server.js",
    "start:mcp": "node dist/mcp/server.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
