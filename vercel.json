{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/web",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://your-railway-app.railway.app/api/:1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
